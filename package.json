{
  "name": "snapline",
  "version": "0.1.0",
  "description": "Snapline — a local-first, project-based screenshot manager for Windows.",
  "author": "João Queirós",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run test:filing && npm run test:ops && npm run test:openai",
    "test:filing": "esbuild test/filing.test.ts --bundle --platform=node --format=cjs --external:electron --outfile=test-out/filing.test.cjs && electron test-out/filing.test.cjs",
    "test:ops": "esbuild test/ops.test.ts --bundle --platform=node --format=cjs --external:electron --outfile=test-out/ops.test.cjs && electron test-out/ops.test.cjs",
    "test:openai": "esbuild test/openai.test.ts --bundle --platform=node --format=cjs --outfile=test-out/openai.test.cjs && node test-out/openai.test.cjs",
    "test:search": "esbuild test/search.test.ts --bundle --platform=node --format=cjs --outfile=test-out/search.test.cjs && node test-out/search.test.cjs",
    "dist": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "dist:dir": "electron-vite build && electron-builder --win --dir --config electron-builder.yml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.9",
    "flexsearch": "^0.7.43",
    "konva": "^9.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
